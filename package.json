{
  "name": "safe-link-checker-monorepo",
  "private": true,
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "test": "npm run test --workspaces --if-present",
    "build": "npm run build -w safe-link-checker && npm run build -w safe-link-checker-cli -w safe-link-checker-api -w @safe-link-checker/api -w playground --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "prepare": "husky"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@cyclonedx/cyclonedx-npm": "^5.0.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@types/validator": "^13.15.10",
    "eslint-plugin-security": "^4.0.1",
    "fast-check": "^4.8.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "typescript": "^5.5.4"
  },
  "size-limit": [
    {
      "path": "packages/safe-link-checker/dist/index.js",
      "limit": "200 kB",
      "name": "safe-link-checker (Node)"
    },
    {
      "path": "packages/safe-link-checker/dist/browser/index.js",
      "limit": "100 kB",
      "name": "safe-link-checker (Browser)"
    }
  ],
  "version": "0.0.0"
}
